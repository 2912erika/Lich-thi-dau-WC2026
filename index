        "Vòng Tứ Kết": [
          {
            t: 97,
            d: "10/07",
            g: "03:00",
            h: "Thắng trận 89",
            a: "Thắng trận 90",
          },
          {
            t: 98,
            d: "11/07",
            g: "02:00",
            h: "Thắng trận 93",
            a: "Thắng trận 94",
          },
          {
            t: 99,
            d: "12/07",
            g: "04:00",
            h: "Thắng trận 91",
