          },
          {
            t: 100,
            d: "12/07",
            g: "08:00",
            h: "Thắng trận 95",
            a: "Thắng trận 96",
          },
        ],
      };

      function toggleMenu() {
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("overlay");
        sidebar.classList.toggle("active");
        overlay.style.display = sidebar.classList.contains("active")
          ? "block"
          : "none";
      }

      function initHomeMode() {
        document.getElementById("display-title").innerText = "Vòng Bảng";
        const subNav = document.getElementById("sub-navigation");
        subNav.innerHTML = "";
        Object.keys(groupTeams).forEach((id) => {
          const btn = document.createElement("button");
          btn.className =
            "phase-btn px-6 py-3 rounded-2xl font-black uppercase";
          btn.innerText = "Bảng " + id;
          btn.onclick = () => renderGroupIcons(id, btn);
          subNav.appendChild(btn);
        });
        renderGroupIcons("A", subNav.firstChild);
      }

      function renderGroupIcons(id, btn) {
        document
          .querySelectorAll(".phase-btn")
          .forEach((b) => b.classList.remove("active"));
        if (btn) btn.classList.add("active");
        const teams = groupTeams[id];
        document.getElementById("main-display").innerHTML = `
            <div class="grid grid-cols-2 md:grid-cols-4 gap-12 w-full max-w-6xl mx-auto">
                ${teams
                  .map(
                    (t) => `
                    <div class="team-circle rounded-[3rem] glass" onclick="showMatchesByTeam('${t.n}')">
                        <img src="https://flagcdn.com/w320/${t.c}.png" class="w-24 h-24 rounded-full object-cover mb-6 border-4 border-white/20 shadow-2xl pointer-events-none">
                        <span class="font-black text-2xl uppercase text-white text-center tracking-tighter">${t.n}</span>
                        <span class="text-[10px] text-[#D4AF37] mt-2 font-bold uppercase tracking-widest">Xem lịch đấu</span>
                    </div>`
                  )
                  .join("")}
            </div>`;
      }

      function showMatchesByTeam(teamName) {
        document.getElementById("display-title").innerText =
          "Lịch Thi Đấu: " + teamName;
        document
          .querySelectorAll(".phase-btn")
          .forEach((b) => b.classList.remove("active"));

        let matchesFound = [];
        Object.keys(vongBangDays).forEach((day) => {
          vongBangDays[day].forEach((m) => {
            if (m.h === teamName || m.a === teamName) {
              matchesFound.push({ ...m, date: day });
            }
          });
        });

        const displayArea = document.getElementById("main-display");
        if (matchesFound.length === 0) {
          displayArea.innerHTML = `<p class="text-slate-400 text-xl font-bold uppercase">Chưa cập nhật trận đấu cho đội này.</p>`;
          return;
        }

        displayArea.innerHTML = `
            <div class="space-y-6 w-full max-w-5xl">
                <button onclick="initHomeMode()" class="mb-4 text-[#D4AF37] hover:text-white font-black text-sm uppercase flex items-center gap-2">
                   <i class="fa-solid fa-arrow-left"></i> Quay lại các bảng
                </button>
                ${matchesFound
                  .map(
                    (m) => `
                    <div class="glass p-8 rounded-[3rem] border border-white/10 flex items-center justify-between hover:bg-white/5 transition-all">
                        <div class="w-32 text-left">
                            <span class="block text-[#D4AF37] font-black text-4xl worldcup-font">${
                              m.t
                            }</span>
                            <span class="text-xs text-white font-bold uppercase tracking-widest">${
                              m.date
                            }</span>
                            <span class="block text-[10px] text-slate-500 font-bold uppercase">Bảng ${
                              m.g
                            }</span>
                        </div>
                        <div class="flex-1 text-center font-black uppercase text-2xl text-white tracking-tight px-4">
                            <span class="${
                              m.h === teamName ? "text-[#D4AF37]" : ""
                            }">${m.h}</span>
                            <span class="px-8 text-[#00f2ff] italic opacity-40 text-lg">vs</span>
                            <span class="${
                              m.a === teamName ? "text-[#D4AF37]" : ""
                            }">${m.a}</span>
                        </div>
                    </div>`
                  )
                  .join("")}
            </div>`;
        displayArea.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      function switchToDayMode() {
        toggleMenu();
        document.getElementById("display-title").innerText =
          "Lịch Thi Đấu Theo Ngày";
        const subNav = document.getElementById("sub-navigation");
        subNav.innerHTML = "";
        Object.keys(vongBangDays).forEach((day) => {
          const btn = document.createElement("button");
          btn.className =
            "phase-btn px-6 py-3 rounded-2xl font-black uppercase";
          btn.innerText = day;
          btn.onclick = () => renderVongBangDay(day, btn);
          subNav.appendChild(btn);
        });
        renderVongBangDay("12/06", subNav.firstChild);
      }

      function renderVongBangDay(day, btn) {
        document
          .querySelectorAll(".phase-btn")
          .forEach((b) => b.classList.remove("active"));
        if (btn) btn.classList.add("active");
        const matches = vongBangDays[day];
        document.getElementById("main-display").innerHTML = `
            <div class="space-y-6 w-full max-w-5xl">
                ${matches
                  .map(
                    (m) => `
                    <div class="glass p-8 rounded-[3rem] border border-white/10 flex items-center justify-between hover:bg-white/5 transition-all">
                        <div class="w-32 text-left"><span class="block text-[#D4AF37] font-black text-4xl worldcup-font">${m.t}</span><span class="text-xs text-slate-500 font-bold uppercase tracking-widest">Bảng ${m.g}</span></div>
                        <div class="flex-1 text-center font-black uppercase text-2xl text-white tracking-tight px-4">
                            <span>${m.h}</span><span class="px-8 text-[#00f2ff] italic opacity-40 text-lg">vs</span><span>${m.a}</span>
                        </div>
                    </div>`
                  )
                  .join("")}
            </div>`;
      }

      function renderKnockout(phase) {
        toggleMenu();
        document.getElementById("display-title").innerText = phase;
        document.getElementById("sub-navigation").innerHTML = "";
        const matches = knockoutData[phase] || [];
        document.getElementById("main-display").innerHTML = `
            <div class="space-y-6 w-full max-w-5xl">
                ${matches
                  .map(
                    (m) => `
                    <div class="glass p-8 rounded-[3rem] flex items-center justify-between">
                        <div class="w-32 text-left"><span class="block text-[#D4AF37] font-black text-4xl worldcup-font">#${m.t}</span><span class="text-xs text-slate-500 font-bold uppercase">${m.d}</span></div>
                        <div class="flex-1 text-center font-black uppercase text-2xl text-white"><span>${m.h}</span><span class="px-6 text-[#00f2ff] italic opacity-30 text-lg">vs</span><span>${m.a}</span></div>
                        <div class="w-32 text-right font-black text-[#00f2ff] text-3xl">${m.g}</div>
                    </div>`
                  )
                  .join("")}
            </div>`;
      }

      function triggerFinal() {
        toggleMenu();
        document.getElementById("display-title").innerText = "Chung Kết";
        document.getElementById("sub-navigation").innerHTML = "";
        confetti({
          particleCount: 300,
          spread: 120,
          origin: { y: 0.6 },
          colors: ["#ffffff", "#D4AF37", "#00f2ff"],
        });
        document.getElementById("main-display").innerHTML = `
            <div class="flex flex-col items-center justify-center py-10 w-full">
                <div class="glass p-16 rounded-[5rem] border-2 border-[#D4AF37]/50 w-full max-w-3xl text-center shadow-[0_0_50px_rgba(212,175,55,0.2)]">
                    <span class="block text-[#D4AF37] font-black text-6xl worldcup-font mb-4">#104</span>
                    <span class="text-xl text-slate-400 font-bold block mb-12 tracking-[0.4em]">20 THÁNG 7, 2026</span>
                    <div class="flex items-center justify-center gap-10 mb-10">
                        <span class="text-4xl font-black text-white uppercase">WINNER 101</span>
                        <span class="text-[#D4AF37] worldcup-font text-6xl italic">VS</span>
                        <span class="text-4xl font-black text-white uppercase">WINNER 102</span>
                    </div>
                    <p class="text-[#00f2ff] font-black text-7xl worldcup-font tracking-tighter">02:00</p>
                </div>
            </div>`;
      }

      function updateCountdown() {
        const target = new Date("June 11, 2026 00:00:00").getTime();
        const now = new Date().getTime();
        const diff = target - now;
        const d = Math.floor(diff / (1000 * 60 * 60 * 24));
        const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const s = Math.floor((diff % (1000 * 60)) / 1000);
        document.getElementById("days").innerText =
          d < 10 ? "0" + Math.max(0, d) : d;
        document.getElementById("hours").innerText =
          h < 10 ? "0" + Math.max(0, h) : h;
        document.getElementById("minutes").innerText =
          m < 10 ? "0" + Math.max(0, m) : m;
        document.getElementById("seconds").innerText =
          s < 10 ? "0" + Math.max(0, s) : s;
      }
      setInterval(updateCountdown, 1000);
      updateCountdown();

      const skyConfetti = () => {
        confetti({
          particleCount: 1,
          startVelocity: 0,
          gravity: 0.4,
          origin: { x: Math.random(), y: -0.1 },
          colors: ["#ffffff", "#D4AF37", "#00f2ff"],
        });
        requestAnimationFrame(skyConfetti);
      };
      skyConfetti();

      initHomeMode();
    </script>
  </body>
</html>
