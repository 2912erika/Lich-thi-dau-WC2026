        color: #f8fafc;
        font-family: "Plus Jakarta Sans", sans-serif;
        margin: 0;
        overflow-x: hidden;
      }

      .main-bg-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        overflow: hidden;
      }
      .main-bg {
        width: 110%;
        height: 110%;
        position: absolute;
        top: -5%;
        left: -5%;
        background: linear-gradient(rgba(1, 4, 9, 0.85), rgba(1, 4, 9, 0.95)),
          url("https://library.sportingnews.com/styles/twitter_card_120x120/s3/2025-11/World-Cup-2026-umbrella-FTR-%281%29.jpg?itok=EmUuGN-R");
        background-size: cover;
        background-position: center;
        animation: ken-burns 40s infinite alternate ease-in-out;
      }
      @keyframes ken-burns {
        from {
          transform: scale(1);
        }
        to {
          transform: scale(1.1);
        }
      }

      .glass {
        background: rgba(15, 23, 42, 0.75);
        backdrop-filter: blur(25px);
        border: 1px solid rgba(212, 175, 55, 0.2);
      }
      .worldcup-font {
        font-family: "Goldman", cursive;
      }

      #sidebar {
        position: fixed;
        top: 0;
        left: -350px;
        width: 320px;
        height: 100%;
        background: rgba(1, 10, 25, 0.98);
        backdrop-filter: blur(40px);
        z-index: 1000;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border-right: 1px solid rgba(212, 175, 55, 0.3);
      }
      #sidebar.active {
        left: 0;
      }
      .menu-item {
        padding: 1.5rem 2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        transition: 0.3s;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 15px;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 13px;
        color: #cbd5e1;
      }
      .menu-item:hover {
        background: rgba(212, 175, 55, 0.15);
        color: #d4af37;
      }
      #overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        z-index: 900;
        display: none;
      }

      @keyframes blink-gold {
        0%,
        100% {
          border-color: rgba(212, 175, 55, 0.2);
          box-shadow: 0 0 10px rgba(212, 175, 55, 0.1);
        }
        50% {
          border-color: rgba(212, 175, 55, 1);
          box-shadow: 0 0 25px rgba(212, 175, 55, 0.4);
        }
      }
      .team-circle {
        cursor: pointer;
        transition: all 0.4s ease;
        border: 3px solid rgba(212, 175, 55, 0.3);
        animation: blink-gold 3s infinite ease-in-out;
        aspect-ratio: 1/1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 1.5rem;
      }
      .team-circle:hover {
        transform: scale(1.05);
        background: rgba(212, 175, 55, 0.1);
      }

      .phase-btn {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: 0.2s;
        color: #94a3b8;
        font-size: 12px;
      }
      .phase-btn.active {
        background: #d4af37 !important;
        color: #001f3f !important;
        font-weight: 900;
        transform: scale(1.1);
      }

      #sub-navigation::-webkit-scrollbar {
        height: 4px;
      }
      #sub-navigation::-webkit-scrollbar-thumb {
        background: #d4af37;
        border-radius: 10px;
      }
